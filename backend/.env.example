ELEVENLABS_API_KEY=
ELEVENLABS_MODEL_ID=scribe_v1
ELEVENLABS_STT_URL=https://api.elevenlabs.io/v1/speech-to-text
ELEVENLABS_TTS_MODEL_ID=eleven_multilingual_v2
ELEVENLABS_TTS_BASE_URL=https://api.elevenlabs.io/v1/text-to-speech
ELEVENLABS_VOICES_URL=https://api.elevenlabs.io/v1/voices
ELEVENLABS_TTS_OUTPUT_FORMAT=mp3_44100_128
# Optional fallback if voice cloning fails.
ELEVENLABS_DEFAULT_VOICE_ID=
# Voice search STT language hint. Set to "auto" to disable forcing a language.
VOICE_SEARCH_LANGUAGE_HINT=en
APP_ORIGIN=http://localhost:5173

# MongoDB Atlas
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB_NAME=virsa_ai
MONGODB_MEMORIES_COLLECTION=memories
MONGODB_CHUNKS_COLLECTION=memory_chunks
MONGODB_PLAYBACK_COLLECTION=playback_positions
MONGODB_USERS_COLLECTION=users
MONGODB_AUTH_SESSIONS_COLLECTION=auth_sessions
MONGODB_FAMILY_PEOPLE_COLLECTION=family_people
MONGODB_FAMILY_EDGES_COLLECTION=family_edges
MONGODB_VECTOR_INDEX=memory_chunks_vector_index

# Embeddings (optional but recommended for real semantic retrieval)
EMBEDDING_PROVIDER=vertex
VERTEX_PROJECT_ID=
VERTEX_LOCATION=us-central1
VERTEX_API_KEY=
VERTEX_ACCESS_TOKEN=
VERTEX_EMBEDDING_MODEL=gemini-embedding-001
VERTEX_EMBEDDING_BASE_URL=
VERTEX_STORY_MODEL=gemini-2.0-flash-001
VERTEX_COVER_MODEL=gemini-2.5-flash-image
VERTEX_GENERATIVE_BASE_URL=

# Gemini direct API (alternative provider)
GEMINI_API_KEY=
GEMINI_EMBEDDING_MODEL=gemini-embedding-001
GEMINI_EMBEDDING_BASE_URL=https://generativelanguage.googleapis.com/v1beta
EMBEDDING_DIM=3072

# Sentiment mood tagging (optional)
SENTIMENT_API_URL=
SENTIMENT_API_KEY=

# Store uploaded audio in GridFS in addition to local file path.
STORE_AUDIO_IN_GRIDFS=false

# Auth
JWT_SECRET_KEY=change-me-to-a-long-random-secret
JWT_ALGORITHM=HS256
JWT_ISSUER=virsa-ai
JWT_AUDIENCE=virsa-ai-users
ACCESS_TOKEN_TTL_MINUTES=15
REFRESH_TOKEN_TTL_DAYS=14
REFRESH_TOKEN_HASH_SECRET=
